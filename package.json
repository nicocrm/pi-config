{
  "name": "pi-config",
  "version": "1.0.0",
  "keywords": [
    "pi-package"
  ],
  "dependencies": {
    "pi-subagents": "^0.12.5",
    "pi-superpowers": "^0.2.0"
  },
  "bundledDependencies": [
    "pi-superpowers",
    "pi-subagents"
  ],
  "pi": {
    "extensions": [
      "./extensions",
      "node_modules/pi-superpowers",
      "node_modules/pi-subagents"
    ],
    "skills": [
      "./skills",
      "node_modules/pi-superpowers/skills",
      "!node_modules/pi-superpowers/skills/using-git-worktrees",
      "!node_modules/pi-superpowers/skills/executing-plans",
      "!node_modules/pi-superpowers/skills/test-driven-development",
      "!node_modules/pi-superpowers/skills/verification-before-completion",
      "!node_modules/pi-superpowers/skills/writing-plans"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "bundleDependencies": [
    "pi-superpowers"
  ]
}
